{
  "type": "object",
  "properties": {
    "ariaLabel": {
      "type": "string",
      "description": "Accessible name for the statistics group landmark. Required when no visible title is present, or when multiple statistics groups appear on the same page."
    },
    "title": {
      "type": "string",
      "description": "Heading for the statistics section"
    },
    "stats": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "icon": {
            "type": "string",
            "description": "Icon class name (e.g. \"mg-icon mg-icon-lightbulb\")"
          },
          "label": {
            "type": "string",
            "description": "Label displayed above the value"
          },
          "value": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              }
            ],
            "description": "The main statistic value (e.g. \"1,500+\", \"45%\", \"$223B\")"
          },
          "bottomLabel": {
            "type": "string",
            "description": "Label displayed below the value"
          },
          "summary": {
            "type": "string",
            "format": "html",
            "description": "Descriptive text (sanitized HTML supported)"
          },
          "link": {
            "type": "string",
            "format": "uri",
            "description": "URL to make the stat item clickable"
          }
        },
        "required": [
          "value"
        ]
      },
      "minItems": 1
    },
    "variant": {
      "type": "string",
      "enum": [
        "default",
        "compact",
        "highlighted",
        "negative"
      ],
      "description": "Visual variant",
      "default": "default"
    }
  },
  "required": [
    "stats"
  ],
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/unisdr/undrr-mangrove/schemas/statistic",
  "title": "Statistic",
  "description": "Statistics display with icon, value, labels, and optional description. Used for key metrics and data highlights.",
  "x-mangrove": {
    "version": "1.0.0",
    "phase": 1,
    "implementors": [
      "StatsCard",
      "StatsCardItem"
    ],
    "deviations": {
      "stats[].summary": "Current component uses `summaryText` as the prop name."
    }
  }
}
