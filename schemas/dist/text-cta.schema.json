{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/unisdr/undrr-mangrove/schemas/text-cta",
  "title": "Text CTA",
  "description": "Call-to-action banner with heading, rich text, action buttons, and optional image.",
  "type": "object",
  "properties": {
    "headline": {
      "type": "string",
      "description": "Banner heading text"
    },
    "headlineSize": {
      "type": "string",
      "description": "Font size token for headline (e.g. \"600\", \"800\"). Maps to mg-u-font-size-{value}."
    },
    "headlineLevel": {
      "type": "integer",
      "minimum": 2,
      "maximum": 6,
      "default": 2,
      "description": "Semantic heading level (2-6). Controls the HTML element independently of visual size."
    },
    "text": {
      "type": "string",
      "format": "html",
      "description": "Body text (sanitized HTML supported)"
    },
    "buttons": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string",
            "description": "Display text for the link or button"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Target URL"
          },
          "type": {
            "type": "string",
            "enum": [
              "Primary",
              "Secondary"
            ],
            "description": "Visual style of the button"
          }
        },
        "required": [
          "label"
        ]
      }
    },
    "variant": {
      "type": "string",
      "enum": [
        "primary",
        "secondary",
        "tertiary",
        "quaternary"
      ],
      "description": "Color variant",
      "default": "primary"
    },
    "backgroundColor": {
      "type": "string",
      "description": "Custom CSS background color (overrides variant) (CSS color value)"
    },
    "padding": {
      "type": "string",
      "description": "Custom CSS padding value (overrides theme token)"
    },
    "image": {
      "type": "object",
      "description": "Banner image",
      "properties": {
        "src": {
          "type": "string",
          "format": "uri",
          "description": "Image URL"
        },
        "alt": {
          "type": "string",
          "description": "Alt text for the image"
        }
      },
      "required": [
        "src"
      ]
    },
    "centered": {
      "type": "boolean",
      "description": "Center-align content (automatically disabled when image is set)",
      "default": true
    }
  },
  "x-mangrove": {
    "version": "1.0.0",
    "phase": 1,
    "implementors": [
      "TextCta"
    ],
    "deviations": {
      "image": "Current component uses flat `image` (URL string) and `imageAlt` (string) props. Schema uses a nested image object with src/alt.",
      "image.src": "Maps to current `image` prop (which is a URL string).",
      "image.alt": "Maps to current `imageAlt` prop."
    }
  }
}
