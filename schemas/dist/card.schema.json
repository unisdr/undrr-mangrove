{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/unisdr/undrr-mangrove/schemas/card",
  "title": "Card",
  "description": "Content card representing a single item (article, event, publication) with image, labels, title, summary, and call-to-action. Covers vertical, horizontal, book, and icon card variants.",
  "type": "object",
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              }
            ],
            "description": "Unique identifier for the card item"
          },
          "image": {
            "type": "object",
            "description": "Image with source URL and alt text",
            "properties": {
              "src": {
                "type": "string",
                "format": "uri",
                "description": "Image URL"
              },
              "alt": {
                "type": "string",
                "description": "Alt text for the image"
              }
            },
            "required": [
              "src"
            ]
          },
          "icon": {
            "type": "string",
            "description": "Icon class name (e.g. \"mg-icon mg-icon-globe\")"
          },
          "iconSize": {
            "type": "number",
            "description": "Width/height of icon in pixels",
            "default": 72
          },
          "imageScale": {
            "type": "string",
            "enum": [
              "small",
              "medium",
              "large",
              "full"
            ],
            "description": "Scale preset for icon/image display"
          },
          "iconColor": {
            "type": "string",
            "description": "Background color for the icon badge (CSS color value)"
          },
          "iconFgColor": {
            "type": "string",
            "description": "Foreground color for the icon glyph (CSS color value)"
          },
          "borderColor": {
            "type": "string",
            "description": "Border color for the card (CSS color value)"
          },
          "labels": {
            "type": "array",
            "items": {
              "type": "string",
              "description": "Category or tag label"
            },
            "maxItems": 2,
            "description": "Category labels displayed in the card meta area"
          },
          "visualLabel": {
            "type": "string",
            "description": "Text label rendered above the icon/image in the visual area"
          },
          "title": {
            "type": "string",
            "description": "Card heading text"
          },
          "srOnlyTitle": {
            "type": "boolean",
            "description": "Visually hide title but keep for screen readers (e.g. logo cards)",
            "default": false
          },
          "summary": {
            "type": "string",
            "format": "html",
            "description": "Card body text (sanitized HTML supported)"
          },
          "link": {
            "type": "string",
            "format": "uri",
            "description": "Primary URL for the card"
          },
          "linkText": {
            "type": "string",
            "description": "Text for a text-style link CTA (alternative to button)"
          },
          "button": {
            "type": "string",
            "description": "Button label text"
          },
          "buttonType": {
            "type": "string",
            "enum": [
              "Primary",
              "Secondary"
            ],
            "description": "Button visual style",
            "default": "Primary"
          }
        },
        "required": [
          "title"
        ]
      },
      "minItems": 1
    },
    "variant": {
      "type": "string",
      "enum": [
        "primary",
        "secondary",
        "tertiary",
        "quaternary",
        "default",
        "negative"
      ],
      "description": "Visual variant. Standard cards use primary-quaternary; IconCard uses default/negative.",
      "default": "primary"
    },
    "centered": {
      "type": "boolean",
      "description": "Center-align card content (IconCard only)",
      "default": false
    }
  },
  "required": [
    "items"
  ],
  "x-mangrove": {
    "version": "1.0.0",
    "phase": 1,
    "implementors": [
      "VerticalCard",
      "HorizontalCard",
      "BookCard",
      "HorizontalBookCard",
      "IconCard"
    ],
    "deviations": {
      "items": "Current components use `data` as the prop name for the items array.",
      "items[].image": "Current components use `imgback` (URL string) and `imgalt` (string) as flat properties instead of a nested image object.",
      "items[].image.src": "Maps to current `imgback` prop.",
      "items[].image.alt": "Maps to current `imgalt` prop.",
      "items[].labels": "Current components use `label1` and `label2` as separate string props instead of an array. IconCard uses a single `label` string.",
      "items[].summary": "Current components use `summaryText` as the prop name."
    }
  }
}
