                  ]
                }
              },
              "additionalProperties": true
            }
          },
          "derived_from": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string"
                },
                "item_id": {
                  "type": "string"
                }
              },
              "required": [
                "kind",
