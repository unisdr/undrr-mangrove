              ]
            }
          },
          "reasoning": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "approved_artifacts": {
      "name": "Approved artifacts",
      "description": "Human-reviewed and approved SCSS artifacts ready for implementation.",
      "item_schema": {
        "type": "object",
        "required": [
          "artifact_name",
          "artifact_type",
          "content"
        ],
        "properties": {
          "artifact_name": {
            "type": "string",
            "description": "File name."
          },
          "artifact_type": {
            "type": "string",
            "enum": [
              "scss_partial",
              "scss_entry",
              "storybook_config"
            ],
            "description": "Type of artifact."
          },
          "content": {
            "type": "string",
            "description": "Final file content (may be edited from scss_artifacts version)."
          },
          "line_changes": {
            "type": "string",
            "description": "For modifications, the exact lines changed."
          },
          "implementation_notes": {
            "type": "string",
            "description": "Human-added notes about implementation approach."
          },
          "status": {
            "type": "string",
            "enum": [
              "approved",
              "modified",
