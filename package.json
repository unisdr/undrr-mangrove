{
  "name": "@undrr/undrr-mangrove",
  "version": "1.4.1",
  "description": "Mangrove design System for UNDRR",
  "main": "src/index.js",
  "type": "module",
  "exports": {
    ".": "./src/index.js"
  },
  "scripts": {
    "build:icons": "node scripts/icon-build.cjs",
    "build": "NODE_ENV=production yarn run scss && storybook build -o docs-build-temp --stats-json && webpack --progress && node scripts/ai-manifest/generate-ai-manifest.js",
    "generate-ai-manifest": "node scripts/ai-manifest/generate-ai-manifest.js",
    "validate-manifest": "node scripts/ai-manifest/generate-ai-manifest.js --validate",
    "build:analyze": "ANALYZE=true NODE_ENV=production webpack --progress",
    "dev": "NODE_ENV=development yarn run scss-watch & yarn run storybook",
    "storybook": "NODE_ENV=development storybook dev -p 6006",
    "update-cdn-version": "node scripts/update-cdn-version.js",
    "prescss": "yarn build:icons",
    "scss": "sass ./stories/assets/scss:./stories/assets/css --silence-deprecation import",
    "scss-watch": "sass --watch ./stories/assets/scss:./stories/assets/css --silence-deprecation import",
    "lint": "yarn run lint:css && yarn run lint:js",
    "prettier:check": "prettier --check \"stories/**/*.{js,jsx,ts,tsx,json,css,scss,md,mdx}\" --ignore-path .gitignore",
    "lint:js": "eslint --ignore-pattern '**/Table.jsx' ./stories --fix",
    "lint:css": "stylelint './stories/**/*.scss' --fix",
    "lint:check": "stylelint './stories/**/*.scss' && eslint --ignore-pattern '**/Table.jsx' ./stories --quiet",
    "test": "jest",
    "test:ci": "jest --ci --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --collectCoverage --",
    "update": "yarn upgrade-interactive --latest",
    "watch": "webpack --watch --progress",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:stories": "prettier --write \"./stories/**/*.{js,jsx,ts,tsx,mdx}\"",
    "format:storybook": "prettier --write \"./.storybook/**/*.{js,jsx,ts,tsx}\"",
    "docker-watch": "docker exec -it undrr-mangrove-client-1 bash -c \"yarn watch\"",
    "docker-up": "docker compose up -d",
    "docker-down": "docker compose down",
    "docker-stop": "docker compose stop",
    "docker-restart": "docker compose restart",
    "docker-install": "docker exec -it undrr-mangrove-client-1 bash -c \"yarn install\"",
    "docker-run": "yarn docker-up && yarn docker-install && docker exec -it undrr-mangrove-client-1 bash -c \"yarn run storybook --ci\"",
    "docker-storybook": "NODE_ENV=development storybook dev -p 6006",
    "docker-build": "docker exec -it undrr-mangrove-client-1 bash -c \"yarn run build\"",
    "docker-lint": "docker exec -it undrr-mangrove-client-1 bash -c \"yarn run lint:check\"",
    "docker-update": "docker exec -it undrr-mangrove-client-1 bash -c \"yarn upgrade-interactive\"",
    "docker-test": "docker exec -it undrr-mangrove-client-1 bash -c \"yarn test\""
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
